{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "flutter-watch",
      "type": "shell",
      "command": "flutter",
      "args": ["run"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Launching.*",
          "endsPattern": "^Application finished\\.$"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "flutter-clean-build",
      "type": "shell",
      "command": "flutter",
      "args": ["clean", "&&", "flutter", "run"],
      "isBackground": false,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    },
    {
      "label": "flutter-run-watch",
      "type": "shell",
      "command": "flutter",
      "args": ["run", "--verbose"],
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
